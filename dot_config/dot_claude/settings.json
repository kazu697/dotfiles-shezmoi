{
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:github.com)",
      "Bash(gh *)",
      "Bash(gh api *)",
      "Bash(git *)",
      "Bash(docker *)",
      "Bash(go *)",
      "Bash(git rebase --continue)",
      "Bash(git rebase origin/main)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Read(~/.ssh)",
      "Read(~/.aws)",
      "Bash(aws:*)",
      "Bash(ssh:*)"
    ],
    "ask": ["Bash(gh pr merge *)", "Bash(git reset *)", "Bash(git merge *)"]
  },
  "model": "opusplan",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.config/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "coderabbit@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "language": "日本語",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": ["github.com", "api.github.com"]
    },
    "excludedCommands": ["git", "gh", "docker", "make", "go"]
  },
  "autoUpdatesChannel": "latest",
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/.claude/hooks/worktree-create.sh"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/.claude/hooks/worktree-remove.sh"
          }
        ]
      }
    ]
  }
}
